---
import { getCollection } from 'astro:content';
import PatternPage from '../../components/PatternPage.astro';

export async function getStaticPaths() {
  const entries = await getCollection('creational');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const all = await getCollection('creational');
---
<PatternPage categoryKey="creational" entry={entry} all={all} />
