---
interface Props {
  type?: 'tip' | 'warn' | 'pitfall';
  title?: string;
}
const { type = 'tip', title } = Astro.props;
const icon = type === 'tip' ? '💡' : type === 'warn' ? '⚠️' : '🚫';
const defaultTitle = type === 'tip' ? 'Interview tip' : type === 'warn' ? 'Watch out' : 'Common misuse';
---

<div class={`callout ${type}`}>
  <div class="callout-title"><span aria-hidden="true">{icon}</span> {title || defaultTitle}</div>
  <slot />
</div>
