---
import { withBase } from '../utils/url';

interface Props {
  title: string;
  summary: string;
  path: string;
  tags?: string[];
}
const { title, summary, path, tags = [] } = Astro.props;
const searchBlob = [title, summary, ...tags].join(' ');
---

<a class="card" href={withBase(path)} data-search={searchBlob}>
  <h3>{title}</h3>
  <p>{summary}</p>
  {tags.length > 0 && (
    <div class="pattern-meta">
      {tags.slice(0, 3).map((t) => <span class="tag">{t}</span>)}
    </div>
  )}
</a>
